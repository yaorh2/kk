<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_dark">

    <!-- 顶部信息栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="@color/background_card">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="退出"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:backgroundTint="@color/background_secondary"
            android:padding="8dp"
            android:minWidth="0dp" />

        <Space
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/tvProgress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 / 0"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_gravity="center_vertical" />
    </LinearLayout>

    <!-- K线图表 -->
    <com.kline.training.ui.KlineChartView
        android:id="@+id/klineChart"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- 加载视图 -->
    <FrameLayout
        android:id="@+id/loadingView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="加载中..."
            android:textColor="@color/text_secondary"
            android:layout_gravity="center" />
    </FrameLayout>

    <!-- 账户信息栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="@color/background_card">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvCapital"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="资金: 0"
                android:textSize="12sp"
                android:textColor="@color/text_secondary" />

            <TextView
                android:id="@+id/tvPosition"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="持仓: 0"
                android:textSize="12sp"
                android:textColor="@color/text_secondary" />

            <TextView
                android:id="@+id/tvAvgCost"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="成本: 0"
                android:textSize="12sp"
                android:textColor="@color/text_secondary" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvCurrentPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="现价: 0"
                android:textSize="12sp"
                android:textColor="@color/text_secondary" />

            <TextView
                android:id="@+id/tvTotalValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="总权益: 0"
                android:textSize="12sp"
                android:textColor="@color/text_secondary" />

            <TextView
                android:id="@+id/tvProfitRate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="盈亏: 0%"
                android:textSize="12sp"
                android:textColor="@color/text_secondary" />
        </LinearLayout>
    </LinearLayout>

    <!-- 操作按钮区 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@color/background_card">

        <!-- 仓位选择 -->
        <RadioGroup
            android:id="@+id/rgPosition"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <RadioButton
                android:id="@+id/rbFull"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="全仓"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:buttonTint="@color/red_500" />

            <RadioButton
                android:id="@+id/rbHalf"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="半仓"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:buttonTint="@color/red_500"
                android:checked="true" />

            <RadioButton
                android:id="@+id/rbQuarter"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="1/4仓"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:buttonTint="@color/red_500" />
        </RadioGroup>

        <!-- 交易按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btnBuy"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="买入"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:backgroundTint="@color/red_500"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnSell"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="卖出"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:backgroundTint="@color/green_500"
                android:enabled="false" />
        </LinearLayout>

        <!-- 下一根K线和快速模式 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnNext"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="2"
                android:text="下一根K线"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:backgroundTint="@color/background_secondary"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnFastMode"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="快速模式"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:backgroundTint="@color/background_secondary" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
